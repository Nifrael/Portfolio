---
const menuItems = [
  { href: "#projets", label: "PROJETS" },
  { href: "#a-propos", label: "A PROPOS" },
  { href: "#contact", label: "CONTACT" }
]
---

<header class="navbar-wrapper">
  <nav class="navbar">
    <a href="/" class="logo" aria-label="Home">
      <div class="logo-icon">
        <span class="chevron">&gt;</span><span class="underscore">_</span>
      </div>
      <div class="logo-text">
        NIFRA<span class="underscore">DEV</span>
      </div>
    </a>

    <button class="menu-toggle" aria-label="Toggle navigation" aria-expanded="false" id="navbar-toggle">
      <span class="hamburger"></span>
    </button>

    <div class="nav-content" id="navbar-content">
      <ul class="menu-items">
        {
          menuItems.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>

      <div class="actions">
        <a href="#init" class="btn-initialize">
          VOIR<span class="arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('navbar-toggle');
  const content = document.getElementById('navbar-content');
  const hamburger = document.querySelector('.hamburger');

  if (toggle && content && hamburger) {
    toggle.addEventListener('click', () => {
      const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isExpanded));
      content.classList.toggle('is-open');
      hamburger.classList.toggle('is-active');
    });
  }
</script>

<style lang="scss">
  @use "@styles/config/variables" as *;
  @use "@styles/config/mixin" as *;

  .navbar-wrapper {
    position: fixed;
    top: 1rem;
    width: 100%;
    padding: 0 1rem;
    z-index: 100;

    @include breakpoint-up($breakpoint-desktop) {
      padding: 0 2rem;
      top: 1.5rem;
    }
  }

  .navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bg-surface);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 100px;
    padding: 0.6rem 1rem;
    margin: 0 auto;
    box-shadow: 0 4px 26px var(--shadow-surface);
    max-width: 1200px;

    @include breakpoint-up($breakpoint-tablet) {
      padding: 0.75rem 1rem 0.75rem 1.5rem;
    }
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    color: #fff;
    cursor: pointer;
    transition: opacity 0.2s ease;

    @include breakpoint-up($breakpoint-desktop) {
    &:hover {
      opacity: 0.8;
    }
    }
  }

  .logo-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;

    .chevron {
      color: #fff;
    }

    .underscore {
      color: var(--accent-primary);
    }
  }

  .logo-text {
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 0.15em;

    .underscore {
      color: var(--accent-primary);
    }
  }

  .menu-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease;

    &:hover {
      background: rgba(255, 255, 255, 0.1);
    }
    
    @include breakpoint-up($breakpoint-tablet) {
      display: none;
    }
  }

  .hamburger {
    position: relative;
    width: 18px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: all 0.3s ease;

    &::before,
    &::after {
      content: '';
      position: absolute;
      left: 0;
      width: 18px;
      height: 2px;
      background: #fff;
      border-radius: 2px;
      transition: all 0.3s ease;
    }

    &::before {
      transform: translateY(-6px);
    }

    &::after {
      transform: translateY(6px);
    }

    &.is-active {
      background: transparent;

      &::before {
        transform: rotate(45deg);
      }

      &::after {
        transform: rotate(-45deg);
      }
    }
  }

  .nav-content {
    display: none;

    @include breakpoint-up($breakpoint-tablet) {
      display: flex;
      align-items: center;
      gap: 2rem;
    }
    
    @include breakpoint-up($breakpoint-desktop) {
      gap: 4rem;
    }

    &.is-open {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: calc(100% + 1rem);
      left: 1rem;
      right: 1rem;
      background: rgba(10, 10, 12, 0.95);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 1.5rem;
      padding: 2rem;
      gap: 2rem;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);

      @include breakpoint-up($breakpoint-tablet) {
        position: static;
        flex-direction: row;
        background: none;
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
        border: none;
        padding: 0;
        box-shadow: none;
      }
    }
  }

  .menu-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
    
    @include breakpoint-up($breakpoint-tablet) {
      flex-direction: row;
      gap: 2rem;
      flex: 1;
      justify-content: center;
    }

    a {
      color: rgba(255, 255, 255, 0.5);
      text-decoration: none;
      font-family: var(--font-body-mono);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      transition: color 0.3s ease;

      &:hover {
        color: #fff;
      }
    }
  }

  .actions {
    display: flex;
    justify-content: center;
  }

  .btn-initialize {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1.25rem;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: transparent;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-body-mono);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;

    &:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.4);
      transform: translateY(-1px);
    }

    .arrow {
      transition: transform 0.3s ease;
      font-size: 1.2em;
      line-height: 1;
    }

    &:hover .arrow {
      transform: translateX(4px);
    }
  }
</style>