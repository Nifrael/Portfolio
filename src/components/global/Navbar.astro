---
const menuItems = [
  { href: "#projets", label: "PROJETS" },
  { href: "#a-propos", label: "A PROPOS" },
  { href: "#contact", label: "CONTACT" }
]
---

<header class="navbar-wrapper">
  <nav class="navbar">
    <a href="/" class="logo" aria-label="Home">
      <div class="logo-icon">
        <span class="chevron">&gt;</span><span class="underscore">_</span>
      </div>
      <div class="logo-text">
        NIFRA<span class="underscore">DEV</span>
      </div>
    </a>

    <button class="menu-toggle" aria-label="Toggle navigation" aria-expanded="false" id="navbar-toggle">
      <span class="hamburger"></span>
    </button>

    <div class="nav-desktop">
      <ul class="menu-items">
        {
          menuItems.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>

  <div class="nav-mobile" id="navbar-mobile" aria-hidden="true">
    <ul class="menu-items">
      {
        menuItems.map((item) => (
          <li>
            <a href={item.href}>{item.label}</a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  import { initNavbar } from '@scripts/navbar';
  initNavbar();
</script>

<style lang="scss">
  @use "@styles/config/variables" as *;
  @use "@styles/config/mixin" as *;

  .navbar-wrapper {
    position: fixed;
    top: 1.5rem;
    width: 100%;
    padding: 0 1.5rem;
    z-index: 100;

    @include breakpoint-up($breakpoint-desktop) {
      padding: 0 2rem;
      top: 1.5rem;
    }
  }

  .navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bg-surface);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border-surface);
    border-radius: 100px;
    padding: 0.5rem 1rem;
    margin: 0 auto;
    box-shadow: 0 4px 26px var(--shadow-surface);
    max-width: 1200px;

    @include breakpoint-up($breakpoint-tablet) {
      padding: 0.75rem 1rem 0.75rem 1.5rem;
    }
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    cursor: pointer;
    transition: color 0.4s ease;

    @include breakpoint-up($breakpoint-desktop) {
      &:hover {
        color: var(--accent-primary);
      }
    }
  }

  .logo-text {
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.15em;

    .underscore {
      color: var(--accent-primary);
    }

    @include breakpoint-up($breakpoint-desktop) {
      font-size: unset;
    }
  }

  .logo-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;

    .chevron {
      color: #fff;
    }

    .underscore {
      color: var(--accent-primary);
    }
  }

  .menu-toggle {
    appearance: none;
    -webkit-appearance: none;
    background: none;
    border: none;
    outline: none;
    box-shadow: none;
    padding: 0;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    cursor: pointer;

    @include breakpoint-up($breakpoint-tablet) {
      display: none;
    }
  }

  .hamburger {
    position: relative;
    width: 18px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: all 0.3s ease;

    &::before,
    &::after {
      content: '';
      position: absolute;
      left: 0;
      width: 18px;
      height: 2px;
      background: var(--text-primary);
      border-radius: 2px;
      transition: all 0.3s ease;
    }

    &::before {
      transform: translateY(-6px);
    }

    &::after {
      transform: translateY(6px);
    }

    &.is-active {
      background: transparent;

      &::before {
        transform: rotate(45deg);
      }

      &::after {
        transform: rotate(-45deg);
      }
    }
  }

  .nav-desktop {
    display: none;

    @include breakpoint-up($breakpoint-tablet) {
      display: flex;
      align-items: center;
      gap: 2rem;
    }

    @include breakpoint-up($breakpoint-desktop) {
      gap: 4rem;
    }
  }

  .nav-mobile {
    display: flex;
    flex-direction: column;
    position: absolute;
    top: calc(100% + 1rem);
    left: 1rem;
    right: 1rem;
    background: var(--bg-surface);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--border-surface);
    border-radius: 1.5rem;
    padding: 2rem;
    gap: 2rem;

    opacity: 0;
    visibility: hidden;
    transform: translateY(-12px);
    pointer-events: none;
    transition:
      opacity 0.25s ease,
      transform 0.25s ease,
      visibility 0s linear 0.25s; 

    &.is-open {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      pointer-events: auto;
      transition:
        opacity 0.25s ease,
        transform 0.25s ease,
        visibility 0s linear 0s; 

      li {
        opacity: 0;
        transform: translateY(-6px);
        animation: navItemIn 0.3s ease forwards;

        @for $i from 1 through 5 {
          &:nth-child(#{$i}) {
            animation-delay: #{$i * 0.06}s;
          }
        }
      }
    }

    @include breakpoint-up($breakpoint-tablet) {
      display: none;
    }
  }

  @keyframes navItemIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }


  .menu-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    margin: 0;
    padding: 0;

    @include breakpoint-up($breakpoint-tablet) {
      flex-direction: row;
      gap: 2rem;
      flex: 1;
      justify-content: center;
    }

    a {
      color: var(--text-primary);
      text-decoration: none;
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 400;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      transition: color 0.4s ease;

      @include breakpoint-up($breakpoint-tablet) {
        &:hover {
          color: var(--accent-primary);
        }
      }
    }
  }
</style>